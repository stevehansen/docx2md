<suki:SukiWindow xmlns="https://github.com/avaloniaui"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:vm="using:Docx2Md.UI.ViewModels"
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
         xmlns:md="https://github.com/whistyun/Markdown.Avalonia"
         xmlns:suki="https://github.com/kikipoulet/SukiUI"
         mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="700"
         x:Class="Docx2Md.UI.Views.MainWindow"
         x:DataType="vm:MainWindowViewModel"
         Icon="/Assets/avalonia-logo.ico"
         Title="DOCX → Markdown Translation Workbench"
         Width="1200" Height="700">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <DockPanel>
        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="File">
                <MenuItem Header="Open DOCX..." Command="{Binding OpenFileCommand}" HotKey="Ctrl+O" />
                <MenuItem Header="Export Markdown..." Command="{Binding ExportMarkdownCommand}" HotKey="Ctrl+E" IsEnabled="{Binding HasDocument}" />
                <Separator />
                <MenuItem Header="Exit" Command="{Binding ExitCommand}" />
            </MenuItem>
            <MenuItem Header="View">
                <MenuItem Header="Show DOCX Preview" IsChecked="{Binding ShowDocxPreview}" />
                <MenuItem Header="Show Segment Inspector" IsChecked="{Binding ShowSegmentInspector}" />
                <MenuItem Header="Show Markdown Preview" IsChecked="{Binding ShowMarkdownPreview}" />
            </MenuItem>
            <MenuItem Header="Settings">
                <MenuItem Header="Enable Style-Based Heading Detection" IsChecked="{Binding Settings.EnableStyleBasedHeadingDetection}" />
                <MenuItem Header="Infer Headings From Formatting" IsChecked="{Binding Settings.InferHeadingsFromFormatting}" />
                <MenuItem Header="Convert Underline to Emphasis" IsChecked="{Binding Settings.ConvertUnderlineToEmphasis}" />
                <MenuItem Header="Generate Diagnostic Report" IsChecked="{Binding Settings.GenerateDiagnosticReport}" />
            </MenuItem>
        </Menu>

        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom" Padding="8" BorderThickness="0,1,0,0"
                Background="{DynamicResource SukiLowBackground}"
                BorderBrush="{DynamicResource SukiBorderBrush}">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="{DynamicResource SukiText}" />
        </Border>

        <!-- Main Content: Three-Pane Layout -->
        <Grid ColumnDefinitions="*,5,*,5,*">
            
            <!-- Left Pane: DOCX Preview -->
            <Border Grid.Column="0" BorderBrush="{DynamicResource SukiBorderBrush}" BorderThickness="1" Margin="5"
                    IsVisible="{Binding ShowDocxPreview}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="DOCX Preview" FontWeight="Bold"
                               Padding="5" Background="{DynamicResource SukiCardBackground}" />
                    <ScrollViewer>
                        <StackPanel Margin="10">
                            <TextBlock Text="{Binding DocumentTitle}" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" />
                            <TextBlock Text="{Binding DocxPreviewText}" TextWrapping="Wrap" />
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Splitter 1 -->
            <GridSplitter Grid.Column="1" Background="{DynamicResource SukiBorderBrush}" ResizeDirection="Columns"
                          IsVisible="{Binding ShowDocxPreview}" />

            <!-- Middle Pane: Segment Inspector -->
            <Border Grid.Column="2" BorderBrush="{DynamicResource SukiBorderBrush}" BorderThickness="1" Margin="5"
                    IsVisible="{Binding ShowSegmentInspector}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Segment Inspector" FontWeight="Bold"
                               Padding="5" Background="{DynamicResource SukiCardBackground}" />
                    <DataGrid ItemsSource="{Binding Segments}"
                              SelectedItem="{Binding SelectedSegment}"
                              AutoGenerateColumns="False"
                              IsReadOnly="False"
                              GridLinesVisibility="All"
                              CanUserReorderColumns="True"
                              CanUserResizeColumns="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding OrderIndex}" Width="50" IsReadOnly="True" />
                            <DataGridTextColumn Header="Type" Binding="{Binding EffectiveType}" Width="100" IsReadOnly="True" />
                            <DataGridTextColumn Header="Style" Binding="{Binding Metadata.StyleName}" Width="120" IsReadOnly="True" />
                            <DataGridTextColumn Header="Content" Binding="{Binding Content}" Width="200" IsReadOnly="True" />
                            <DataGridTextColumn Header="Markdown" Binding="{Binding EffectiveMarkdown}" Width="200" IsReadOnly="True" />
                            <DataGridTextColumn Header="Diagnostics" Binding="{Binding Diagnostics.Count}" Width="100" IsReadOnly="True" />
                            <DataGridCheckBoxColumn Header="Exclude" Binding="{Binding ExcludeFromOutput}" Width="80" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- Splitter 2 -->
            <GridSplitter Grid.Column="3" Background="{DynamicResource SukiBorderBrush}" ResizeDirection="Columns"
                          IsVisible="{Binding ShowSegmentInspector}" />

            <!-- Right Pane: Markdown Preview -->
            <Border Grid.Column="4" BorderBrush="{DynamicResource SukiBorderBrush}" BorderThickness="1" Margin="5"
                    IsVisible="{Binding ShowMarkdownPreview}">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Background="{DynamicResource SukiCardBackground}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Markdown Preview" FontWeight="Bold"
                                   Padding="5" VerticalAlignment="Center" />
                        <ToggleButton Grid.Column="1" Content="Raw" IsChecked="{Binding ShowRawMarkdown}"
                                      Margin="5" Padding="8,4" />
                    </Grid>
                    <ScrollViewer>
                        <StackPanel Margin="10">
                            <!-- Rendered Markdown -->
                            <md:MarkdownScrollViewer Markdown="{Binding MarkdownOutput}" 
                                                     IsVisible="{Binding !ShowRawMarkdown}" />
                            <!-- Raw Markdown -->
                            <TextBox Text="{Binding MarkdownOutput}" 
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     FontFamily="Consolas,Courier New,monospace"
                                     IsVisible="{Binding ShowRawMarkdown}"
                                     Background="White" />
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>

</suki:SukiWindow>
