<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Docx2Md.UI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:md="https://github.com/whistyun/Markdown.Avalonia"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="700"
        x:Class="Docx2Md.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="DOCX → Markdown Translation Workbench"
        Width="1200" Height="700">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <DockPanel>
        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Open DOCX..." Command="{Binding OpenFileCommand}" HotKey="Ctrl+O" />
                <MenuItem Header="_Export Markdown..." Command="{Binding ExportMarkdownCommand}" HotKey="Ctrl+E" IsEnabled="{Binding HasDocument}" />
                <Separator />
                <MenuItem Header="E_xit" Command="{Binding ExitCommand}" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="Show _DOCX Preview" IsChecked="{Binding ShowDocxPreview}" />
                <MenuItem Header="Show _Segment Inspector" IsChecked="{Binding ShowSegmentInspector}" />
                <MenuItem Header="Show _Markdown Preview" IsChecked="{Binding ShowMarkdownPreview}" />
            </MenuItem>
            <MenuItem Header="_Settings">
                <MenuItem Header="Enable Style-Based Heading Detection" IsChecked="{Binding Settings.EnableStyleBasedHeadingDetection}" />
                <MenuItem Header="Infer Headings From Formatting" IsChecked="{Binding Settings.InferHeadingsFromFormatting}" />
                <MenuItem Header="Convert Underline to Emphasis" IsChecked="{Binding Settings.ConvertUnderlineToEmphasis}" />
                <MenuItem Header="Generate Diagnostic Report" IsChecked="{Binding Settings.GenerateDiagnosticReport}" />
            </MenuItem>
        </Menu>

        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom" Background="#F0F0F0" Padding="5" BorderBrush="#CCCCCC" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusText}" />
        </Border>

        <!-- Main Content: Three-Pane Layout -->
        <Grid ColumnDefinitions="*,5,*,5,*">
            
            <!-- Left Pane: DOCX Preview -->
            <Border Grid.Column="0" BorderBrush="#CCCCCC" BorderThickness="1" Margin="5" 
                    IsVisible="{Binding ShowDocxPreview}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="DOCX Preview" FontWeight="Bold" 
                               Padding="5" Background="#E8E8E8" />
                    <ScrollViewer>
                        <StackPanel Margin="10">
                            <TextBlock Text="{Binding DocumentTitle}" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" />
                            <TextBlock Text="{Binding DocxPreviewText}" TextWrapping="Wrap" />
                            <TextBlock Text="(Read-only preview of original document)" 
                                       FontStyle="Italic" Foreground="#888888" Margin="0,10,0,0"
                                       IsVisible="{Binding !HasDocument}" />
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Splitter 1 -->
            <GridSplitter Grid.Column="1" Background="#CCCCCC" ResizeDirection="Columns" 
                          IsVisible="{Binding ShowDocxPreview}" />

            <!-- Middle Pane: Segment Inspector -->
            <Border Grid.Column="2" BorderBrush="#CCCCCC" BorderThickness="1" Margin="5"
                    IsVisible="{Binding ShowSegmentInspector}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Segment Inspector" FontWeight="Bold" 
                               Padding="5" Background="#E8E8E8" />
                    <DataGrid ItemsSource="{Binding Segments}"
                              SelectedItem="{Binding SelectedSegment}"
                              AutoGenerateColumns="False"
                              IsReadOnly="False"
                              GridLinesVisibility="All"
                              CanUserReorderColumns="True"
                              CanUserResizeColumns="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding OrderIndex}" Width="50" IsReadOnly="True" />
                            <DataGridTextColumn Header="Type" Binding="{Binding EffectiveType}" Width="100" IsReadOnly="True" />
                            <DataGridTextColumn Header="Style" Binding="{Binding Metadata.StyleName}" Width="120" IsReadOnly="True" />
                            <DataGridTextColumn Header="Content" Binding="{Binding Content}" Width="200" IsReadOnly="True" />
                            <DataGridTextColumn Header="Markdown" Binding="{Binding EffectiveMarkdown}" Width="200" IsReadOnly="True" />
                            <DataGridTextColumn Header="Diagnostics" Binding="{Binding Diagnostics.Count}" Width="100" IsReadOnly="True" />
                            <DataGridCheckBoxColumn Header="Exclude" Binding="{Binding ExcludeFromOutput}" Width="80" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- Splitter 2 -->
            <GridSplitter Grid.Column="3" Background="#CCCCCC" ResizeDirection="Columns"
                          IsVisible="{Binding ShowSegmentInspector}" />

            <!-- Right Pane: Markdown Preview -->
            <Border Grid.Column="4" BorderBrush="#CCCCCC" BorderThickness="1" Margin="5"
                    IsVisible="{Binding ShowMarkdownPreview}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Background="#E8E8E8" Spacing="10">
                        <TextBlock Text="Markdown Preview" FontWeight="Bold" Padding="5" />
                        <ToggleButton Content="Raw" IsChecked="{Binding ShowRawMarkdown}" Margin="5" />
                    </StackPanel>
                    <ScrollViewer>
                        <StackPanel Margin="10">
                            <!-- Rendered Markdown -->
                            <md:MarkdownScrollViewer Markdown="{Binding MarkdownOutput}" 
                                                     IsVisible="{Binding !ShowRawMarkdown}" />
                            <!-- Raw Markdown -->
                            <TextBox Text="{Binding MarkdownOutput}" 
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     FontFamily="Consolas,Courier New,monospace"
                                     IsVisible="{Binding ShowRawMarkdown}"
                                     Background="White" />
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>

</Window>
