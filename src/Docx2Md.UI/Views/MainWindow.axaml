<suki:SukiWindow xmlns="https://github.com/avaloniaui"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:vm="using:Docx2Md.UI.ViewModels"
         xmlns:conv="using:Docx2Md.UI.Converters"
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
         xmlns:md="https://github.com/whistyun/Markdown.Avalonia"
         xmlns:ctxt="clr-namespace:ColorTextBlock.Avalonia;assembly=ColorTextBlock.Avalonia"
         xmlns:suki="https://github.com/kikipoulet/SukiUI"
         mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="700"
         x:Class="Docx2Md.UI.Views.MainWindow"
         x:DataType="vm:MainWindowViewModel"
         Icon="/Assets/avalonia-logo.ico"
         Title="DOCX → Markdown Translation Workbench"
         Width="1200" Height="700">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <!-- Keyboard Shortcuts -->
    <suki:SukiWindow.KeyBindings>
        <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenFileCommand}" />
        <KeyBinding Gesture="Ctrl+E" Command="{Binding ExportMarkdownCommand}" />
        <KeyBinding Gesture="F5" Command="{Binding ToggleDocxPreviewCommand}" />
        <KeyBinding Gesture="F6" Command="{Binding ToggleSegmentInspectorCommand}" />
        <KeyBinding Gesture="F7" Command="{Binding ToggleMarkdownPreviewCommand}" />
    </suki:SukiWindow.KeyBindings>

    <DockPanel>
        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="File">
                <MenuItem Header="Open DOCX..." Command="{Binding OpenFileCommand}" InputGesture="Ctrl+O" />
                <MenuItem Header="Export Markdown..." Command="{Binding ExportMarkdownCommand}" InputGesture="Ctrl+E" IsEnabled="{Binding HasDocument}" />
                <Separator />
                <MenuItem Header="Exit" Command="{Binding ExitCommand}" InputGesture="Alt+F4" />
            </MenuItem>
            <MenuItem Header="View">
                <MenuItem Header="Show DOCX Preview"
                          Command="{Binding ToggleDocxPreviewCommand}"
                          InputGesture="F5">
                    <MenuItem.Icon>
                        <CheckBox IsChecked="{Binding ShowDocxPreview}" BorderThickness="0" IsHitTestVisible="False" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Show Segment Inspector"
                          Command="{Binding ToggleSegmentInspectorCommand}"
                          InputGesture="F6">
                    <MenuItem.Icon>
                        <CheckBox IsChecked="{Binding ShowSegmentInspector}" BorderThickness="0" IsHitTestVisible="False" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Show Markdown Preview"
                          Command="{Binding ToggleMarkdownPreviewCommand}"
                          InputGesture="F7">
                    <MenuItem.Icon>
                        <CheckBox IsChecked="{Binding ShowMarkdownPreview}" BorderThickness="0" IsHitTestVisible="False" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="Settings">
                <MenuItem Header="Enable Style-Based Heading Detection"
                          Command="{Binding ToggleStyleBasedHeadingDetectionCommand}">
                    <MenuItem.Icon>
                        <CheckBox IsChecked="{Binding EnableStyleBasedHeadingDetection}" BorderThickness="0" IsHitTestVisible="False" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Infer Headings From Formatting"
                          Command="{Binding ToggleInferHeadingsFromFormattingCommand}">
                    <MenuItem.Icon>
                        <CheckBox IsChecked="{Binding InferHeadingsFromFormatting}" BorderThickness="0" IsHitTestVisible="False" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Convert Underline to Emphasis"
                          Command="{Binding ToggleConvertUnderlineToEmphasisCommand}">
                    <MenuItem.Icon>
                        <CheckBox IsChecked="{Binding ConvertUnderlineToEmphasis}" BorderThickness="0" IsHitTestVisible="False" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Generate Diagnostic Report"
                          Command="{Binding ToggleGenerateDiagnosticReportCommand}">
                    <MenuItem.Icon>
                        <CheckBox IsChecked="{Binding GenerateDiagnosticReport}" BorderThickness="0" IsHitTestVisible="False" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
        </Menu>

        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom" Padding="8" BorderThickness="0,1,0,0"
                Background="{DynamicResource SukiLowBackground}"
                BorderBrush="{DynamicResource SukiBorderBrush}">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="{DynamicResource SukiText}" />
        </Border>

        <!-- Main Content: Three-Pane Layout using DockPanel for proper collapse -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding ShowDocxPreview, Converter={x:Static conv:BoolToGridLengthConverter.Instance}}" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="{Binding ShowSegmentInspector, Converter={x:Static conv:BoolToGridLengthConverter.Instance}}" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="{Binding ShowMarkdownPreview, Converter={x:Static conv:BoolToGridLengthConverter.Instance}}" />
            </Grid.ColumnDefinitions>

            <!-- Left Pane: DOCX Preview -->
            <Border Grid.Column="0" BorderBrush="{DynamicResource SukiBorderBrush}" BorderThickness="1" Margin="5"
                    IsVisible="{Binding ShowDocxPreview}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="DOCX Preview" FontWeight="Bold"
                               Padding="5" Background="{DynamicResource SukiCardBackground}" />
                    <ScrollViewer>
                        <StackPanel Margin="10">
                            <TextBlock Text="{Binding DocumentTitle}" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" />
                            <TextBlock Text="{Binding DocxPreviewText}" TextWrapping="Wrap" />
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Splitter 1 -->
            <GridSplitter Grid.Column="1" Width="5" Background="{DynamicResource SukiBorderBrush}" ResizeDirection="Columns"
                          IsVisible="{Binding ShowDocxPreview}" />

            <!-- Middle Pane: Segment Inspector -->
            <Border Grid.Column="2" BorderBrush="{DynamicResource SukiBorderBrush}" BorderThickness="1" Margin="5"
                    IsVisible="{Binding ShowSegmentInspector}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Segment Inspector" FontWeight="Bold"
                               Padding="5" Background="{DynamicResource SukiCardBackground}" />

                    <!-- Segment List (simplified) -->
                    <DataGrid DockPanel.Dock="Top"
                              ItemsSource="{Binding Segments}"
                              SelectedItem="{Binding SelectedSegment}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              GridLinesVisibility="All"
                              CanUserReorderColumns="True"
                              CanUserResizeColumns="True"
                              MinHeight="150"
                              MaxHeight="300">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding OrderIndex}" Width="40" />
                            <DataGridTextColumn Header="Type" Binding="{Binding EffectiveType}" Width="80" />
                            <DataGridTextColumn Header="Style" Binding="{Binding Metadata.StyleName}" Width="100" />
                            <DataGridTextColumn Header="Content" Binding="{Binding Content}" Width="*" />
                            <DataGridTextColumn Header="Diag" Binding="{Binding DiagnosticCount}" Width="45" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Detail Panel (shown when segment selected) -->
                    <Border DockPanel.Dock="Bottom"
                            IsVisible="{Binding SelectedSegment, Converter={x:Static ObjectConverters.IsNotNull}}"
                            Background="{DynamicResource SukiCardBackground}"
                            BorderBrush="{DynamicResource SukiBorderBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="10"
                            Margin="0,5,0,0">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Segment Overrides" FontWeight="SemiBold" />

                            <!-- Row 1: Exclude, Heading Level, Type Override -->
                            <Grid ColumnDefinitions="Auto,Auto,*,Auto,*">
                                <CheckBox Grid.Column="0"
                                          Content="Exclude"
                                          IsChecked="{Binding SelectedSegment.ExcludeFromOutput}"
                                          Margin="0,0,15,0" />

                                <TextBlock Grid.Column="1" Text="H-Level:" VerticalAlignment="Center" Margin="0,0,5,0" />
                                <ComboBox Grid.Column="2"
                                          ItemsSource="{Binding AvailableHeadingLevels}"
                                          SelectedItem="{Binding SelectedSegment.OverrideHeadingLevel}"
                                          HorizontalAlignment="Stretch"
                                          Margin="0,0,15,0">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Converter={x:Static conv:HeadingLevelDisplayConverter.Instance}}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <TextBlock Grid.Column="3" Text="Type:" VerticalAlignment="Center" Margin="0,0,5,0" />
                                <ComboBox Grid.Column="4"
                                          ItemsSource="{Binding AvailableSegmentTypes}"
                                          SelectedItem="{Binding SelectedSegment.OverrideType}"
                                          HorizontalAlignment="Stretch">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Converter={x:Static conv:SegmentTypeDisplayConverter.Instance}}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </Grid>

                            <!-- Row 2: Manual Markdown Override -->
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="Manual Markdown Override:" Margin="0,0,0,5" />
                                <TextBox Text="{Binding SelectedSegment.ManualMarkdownOverride}"
                                         Watermark="Leave empty to use converted markdown"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MinHeight="60"
                                         MaxHeight="120" />
                            </DockPanel>

                            <!-- Row 3: Preview of effective markdown -->
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="Effective Markdown:" Margin="0,0,0,5"
                                           Foreground="{DynamicResource SukiLowText}" />
                                <Border Background="{DynamicResource SukiBackground}"
                                        BorderBrush="{DynamicResource SukiBorderBrush}"
                                        BorderThickness="1"
                                        Padding="8"
                                        CornerRadius="4">
                                    <TextBlock Text="{Binding SelectedSegment.EffectiveMarkdown}"
                                               FontFamily="Consolas,Courier New,monospace"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource SukiText}" />
                                </Border>
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <!-- Placeholder when no segment selected -->
                    <Border DockPanel.Dock="Bottom"
                            IsVisible="{Binding SelectedSegment, Converter={x:Static ObjectConverters.IsNull}}"
                            Padding="20">
                        <TextBlock Text="Select a segment to view and edit overrides"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource SukiLowText}" />
                    </Border>
                </DockPanel>
            </Border>

            <!-- Splitter 2 -->
            <GridSplitter Grid.Column="3" Width="5" Background="{DynamicResource SukiBorderBrush}" ResizeDirection="Columns"
                          IsVisible="{Binding ShowSegmentInspector}" />

            <!-- Right Pane: Markdown Preview -->
            <Border Grid.Column="4" BorderBrush="{DynamicResource SukiBorderBrush}" BorderThickness="1" Margin="5"
                    IsVisible="{Binding ShowMarkdownPreview}">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Background="{DynamicResource SukiCardBackground}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Markdown Preview" FontWeight="Bold"
                                   Padding="5" VerticalAlignment="Center" />
                        <ToggleButton Grid.Column="1" Content="Raw" IsChecked="{Binding ShowRawMarkdown}"
                                      Margin="5" Padding="8,4" />
                    </Grid>
                    <ScrollViewer>
                        <StackPanel Margin="10">
                            <!-- Rendered Markdown with theme-aware styling -->
                            <md:MarkdownScrollViewer Markdown="{Binding MarkdownOutput}"
                                                     IsVisible="{Binding !ShowRawMarkdown}">
                                <md:MarkdownScrollViewer.Styles>
                                    <!-- Style headings to use theme text color -->
                                    <Style Selector="ctxt|CTextBlock.Heading1">
                                        <Setter Property="Foreground" Value="{DynamicResource SukiText}" />
                                    </Style>
                                    <Style Selector="ctxt|CTextBlock.Heading2">
                                        <Setter Property="Foreground" Value="{DynamicResource SukiText}" />
                                    </Style>
                                    <Style Selector="ctxt|CTextBlock.Heading3">
                                        <Setter Property="Foreground" Value="{DynamicResource SukiText}" />
                                    </Style>
                                    <Style Selector="ctxt|CTextBlock.Heading4">
                                        <Setter Property="Foreground" Value="{DynamicResource SukiText}" />
                                    </Style>
                                    <Style Selector="ctxt|CTextBlock.Heading5">
                                        <Setter Property="Foreground" Value="{DynamicResource SukiText}" />
                                    </Style>
                                    <Style Selector="ctxt|CTextBlock.Heading6">
                                        <Setter Property="Foreground" Value="{DynamicResource SukiText}" />
                                    </Style>
                                    <!-- Style all other text -->
                                    <Style Selector="ctxt|CTextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource SukiText}" />
                                    </Style>
                                    <Style Selector="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource SukiText}" />
                                    </Style>
                                </md:MarkdownScrollViewer.Styles>
                            </md:MarkdownScrollViewer>
                            <!-- Raw Markdown -->
                            <TextBox Text="{Binding MarkdownOutput}"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     FontFamily="Consolas,Courier New,monospace"
                                     IsVisible="{Binding ShowRawMarkdown}"
                                     Foreground="{DynamicResource SukiText}"
                                     Background="{DynamicResource SukiCardBackground}" />
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>

</suki:SukiWindow>
